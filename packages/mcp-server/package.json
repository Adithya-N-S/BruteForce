{
  "name": "veilbreaker-mcp",
  "version": "0.1.0",
  "description": "BruteForce MCP server for beneficial ownership investigation",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "npm install --prefix src/widgets && npm run build --prefix src/widgets && tsc && node scripts/copy-seed.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "copy-seed": "node scripts/copy-seed.js"
  },
  "dependencies": {
    "@bruteforce/core": "^0.1.0",
    "@nitrostack/core": "^1.0.13",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}