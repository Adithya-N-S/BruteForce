{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "declaration": false,
    "skipLibCheck": true,
    "types": ["node", "express", "uuid"]
  },
  "include": ["src"]
}
